{
	"name": "pi-secrets",
	"version": "0.1.0",
	"description": "Pi extension: the agent requests secrets via a masked local prompt. Values become env vars for bash, never enter the model context, and are redacted from tool output.",
	"type": "module",
	"keywords": [
		"pi-package",
		"pi",
		"pi-coding-agent",
		"secrets",
		"credentials",
		"extension"
	],
	"license": "MIT",
	"author": "Liam Vinberg",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/liamvinberg/pi-secrets.git"
	},
	"bugs": {
		"url": "https://github.com/liamvinberg/pi-secrets/issues"
	},
	"homepage": "https://github.com/liamvinberg/pi-secrets#readme",
	"files": [
		"src/**/*.ts",
		"!src/**/*.test.ts",
		"README.md",
		"CONTEXT.md",
		"LICENSE",
		"docs/**/*.md"
	],
	"scripts": {
		"check": "tsc --noEmit",
		"test": "bun test"
	},
	"pi": {
		"extensions": [
			"./src/index.ts"
		],
		"image": "https://raw.githubusercontent.com/liamvinberg/pi-secrets/main/assets/preview.png"
	},
	"peerDependencies": {
		"@earendil-works/pi-coding-agent": "*",
		"@earendil-works/pi-tui": "*",
		"typebox": "*"
	},
	"devDependencies": {
		"@earendil-works/pi-coding-agent": "0.79.0",
		"@earendil-works/pi-tui": "0.79.0",
		"@types/bun": "1.3.14",
		"@types/node": "25.9.1",
		"typebox": "1.1.38",
		"typescript": "5.9.3"
	}
}
